{
  "name": "@mystery4f/pi-superpowers",
  "version": "5.2.0",
  "description": "Superpowers skills library for Pi: TDD, debugging, collaboration workflows with Chinese trigger support (forked from @weiping/pi-superpowers, updated SDK to @earendil-works)",
  "keywords": [
    "pi-package",
    "skills",
    "tdd",
    "debugging",
    "workflow",
    "chinese"
  ],
  "author": "Forked from obra/superpowers & weiping/pi-superpowers",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/mystery4f/pi-superpowers.git"
  },
  "homepage": "https://github.com/mystery4f/pi-superpowers#readme",
  "bugs": {
    "url": "https://github.com/mystery4f/pi-superpowers/issues"
  },
  "files": [
    "extensions/**/*.ts",
    "skills/**/*.md",
    "prompts/**/*.md",
    "README.md",
    "INSTALL.md",
    "package.json"
  ],
  "pi": {
    "extensions": [
      "./extensions/bootstrap.ts",
      "./extensions/subagent.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude 'tests/brainstorm-server/**' && (cd tests/brainstorm-server && npm install --silent && npm test)",
    "test:watch": "vitest --exclude 'tests/brainstorm-server/**'",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.75.0"
  }
}
